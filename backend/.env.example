# Local development — defaults to SQLite.
APP_ENV=development
SECRET_KEY=generate-with-python-secrets-token-urlsafe
DATABASE_URL=sqlite:///./bidwise.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GEMINI_API_KEY=

# For Docker Compose (PostgreSQL), set these in the root .env instead:
# DATABASE_URL=postgresql+psycopg://bidwise:password@localhost:5432/bidwise
